# Berza Katalizatora — Environment Config
# Kopirati u .env i popuniti vrijednosti

NODE_ENV=production
PORT=3002

# PostgreSQL (lokalna baza na VPS-u)
DATABASE_URL=postgresql://berza:LOZINKA_OVDJE@localhost:5432/berza_db

# JWT — generiraj random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=PROMIJENI_OVO_U_DUGACKI_RANDOM_STRING

# Allowed CORS origin
ALLOWED_ORIGIN=https://berzakatalizatora.com
